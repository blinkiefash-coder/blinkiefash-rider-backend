# Backend Firebase Admin Config
# Get these from Firebase Console > Project Settings > Service Accounts > Generate new private key

FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_CLIENT_EMAIL=YOUR_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY=YOUR_PRIVATE_KEY_WITH_ESCAPED_NEWLINES

# Neon Database (already configured)
DATABASE_URL=postgresql://user:password@host/dbname

# Comma-separated allowed frontend origins for CORS
FRONTEND_URLS=http://localhost:5173

# Optional: allow backend OTP fallback mode in production when Firebase captcha fails
# In non-production this fallback is enabled automatically
ALLOW_SERVER_OTP=false
